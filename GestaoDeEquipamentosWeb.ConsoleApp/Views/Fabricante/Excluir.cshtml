@using GestaoDeEquipamentosWeb.ConsoleApp.ModuloFabricante;

@model Fabricante;

<h2>Exclusão de Fabricantes</h2>

<form action="/Fabricante/Excluir/@Model.Id" method="post">
    <div>
        <label>Nome</label>
        <br>
        <input type="text" name="Nome" value="@Model.Nome" disabled>
    </div>

    <div>
        
        <label>Email</label>
        <br>
        <input type="email" name="Email" value="@Model.Email" disabled>
    </div>

    <div>
        
        <label>Telefone</label>
        <br>
        <input type="text" name="Telefone" value="@Model.Telefone" disabled>
    </div>

    <button type="submit">Confirmar</button>
</form>