@using GestaoDeEquipamentosWeb.ConsoleApp.ModuloFabricante;

@model Fabricante;

<h2>Edição de Fabricantes</h2>

<form action="/Fabricante/Editar" method="post">
    <div>
        <input type="hidden" name="Id" value="@Model.Id">
        <label>Nome</label>
        <br>
        <input type="text" name="Nome" value="@Model.Nome">
    </div>

    <div>
        
        <label>Email</label>
        <br>
        <input type="email" name="Email" value="@Model.Email">
    </div>

    <div>
        
        <label>Telefone</label>
        <br>
        <input type="text" name="Telefone" value="@Model.Telefone">
    </div>

    <button type="submit">Confirmar</button>
</form>