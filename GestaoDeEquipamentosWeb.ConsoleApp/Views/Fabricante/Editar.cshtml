@using GestaoDeEquipamentosWeb.ConsoleApp.Models

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Fabricante";
}

@model EditarFabricanteViewModel;

<form class="formulario" asp-action="Editar" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="formulario-campo">
        <label asp-for="Nome">Nome</label>
        <input asp-for="Nome" type="text">
        <span asp-validation-for="Nome" class="formulario-validacao-campo"></span>
    </div>

    <div class="formulario-campo">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" type="email">
        <span asp-validation-for="Email" class="formulario-validacao-campo"></span>
    </div>

    <div class="formulario-campo">
        <label asp-for="Telefone">Telefone</label>
        <input asp-for="Telefone" type="text">
        <span asp-validation-for="Telefone" class="formulario-validacao-campo"></span>
    </div>

    <div class="formulario-acoes">
        <a asp-action="Listar">Voltar</a> 
        <button type="submit">Confirmar</button>
    </div>
</form>
