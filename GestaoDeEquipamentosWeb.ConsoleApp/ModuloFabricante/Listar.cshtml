@using GestaoDeEquipamentosWeb.ConsoleApp.ModuloFabricante;

@model List<Fabricante>;

<h1>Gestão de Equipamentos</h1>

<hr>
    <a href="/Fabricante/Listar">Controle de Fabricantes</a> -
    <a href="/Equipamento/Listar">Controle de Equipamentos</a> -
    <a href="/Chamado/Listar">Controle de Chamados</a> -
    <a href="https://www.academiadoprogramador.net/inicio" target="_blank">Academia do Progamador</a> -
 <hr>

<h2>Listagem de Fabricantes</h2>

<hr>

<table>
    <thead>
        <tr>
            <td>ID</td>
            <td>Nome</td>
            <td>Email</td>
            <td>Telefone</td>
        </tr>
    </thead>

    <tbody>

        @foreach (Fabricante f in Model)
        {
            <tr>
                <td>@f.Id</td>
                <td>@f.Nome</td>
                <td>@f.Email</td>
                <td>@f.Telefone</td>
            </tr>
        }
    </tbody>

</table>